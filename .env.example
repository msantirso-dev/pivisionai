# =============================================================================
# PI Vision AI - Environment Configuration
# Copy to .env and configure before deployment
# =============================================================================

# Application
APP_NAME=PI Vision AI
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=change-me-to-a-long-random-secret-key-min-32-chars
API_PREFIX=/api/v1
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# Database (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pivision
POSTGRES_USER=pivision
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# JWT Authentication
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage (persistent volumes)
STORAGE_PATH=/data/storage
SNAPSHOTS_PATH=/data/storage/snapshots
CLIPS_PATH=/data/storage/clips
LOGS_PATH=/data/storage/logs
EVIDENCE_PRE_SECONDS=10
EVIDENCE_POST_SECONDS=20

# AI Processing
AI_MODEL=yolov8s.pt
AI_CONFIDENCE=0.35
AI_MIN_OBJECT_SIZE=20
AI_ANALYSIS_WIDTH=640
AI_IMGSZ=1280
AI_DEFAULT_FPS=5
AI_LOAD_PROFILE=medium
AI_DEVICE=cpu
# Set to cuda:0 for NVIDIA GPU
# AI_DEVICE=cuda:0
TENSORRT_ENABLED=false

# LLM Vision Analysis (Ollama local o OpenAI/ChatGPT)
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_ANALYZE_ON_EVENT=true
LLM_DESCRIBE_COOLDOWN_SECONDS=3600
# Ollama (local, sin API key)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llava
# OpenAI / ChatGPT (requiere API key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=800
# LLM_SYSTEM_PROMPT=   # opcional, prompt personalizado

# RTSP Ingestion
RTSP_TIMEOUT=10
RTSP_RECONNECT_DELAY=5
RTSP_MAX_RETRIES=10
USE_SUBSTREAM_FOR_AI=true

# Dahua API (local LAN)
DAHUA_POLL_INTERVAL=2
DAHUA_EVENT_BUFFER_SIZE=100

# Dahua Cloud — Lechange / Imou Open API (https://open.imou.com)
# Crear app en consola Imou y obtener appId + appSecret
DAHUA_CLOUD_APP_ID=
DAHUA_CLOUD_APP_SECRET=
DAHUA_CLOUD_API_BASE=https://openapi.lechange.cn/openapi

# Notifications
WEBHOOK_ENABLED=false
WEBHOOK_DEFAULT_URL=
MQTT_ENABLED=false
MQTT_BROKER=mqtt://localhost:1883
MQTT_TOPIC=pivision/events
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Home Assistant / Fibaro (future)
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
FIBARO_HC3_URL=
FIBARO_HC3_USERNAME=
FIBARO_HC3_PASSWORD=

# System Health
HEALTH_CHECK_INTERVAL=30
DEGRADED_MODE_CPU_THRESHOLD=85
DEGRADED_MODE_GPU_THRESHOLD=90

# Frontend (build-time)
VITE_API_URL=/api/v1
VITE_WS_URL=/ws

# Coolify / Reverse Proxy
DOMAIN=your-domain.com
BACKEND_PORT=8000
FRONTEND_PORT=80
